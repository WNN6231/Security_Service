# ==============================================================================
# Security Service - Environment Variables
# Copy this file to .env and fill in the values.
# ==============================================================================

# ---- Server ----
PORT=8080

# ---- PostgreSQL ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=security_service
# Or use a single connection string (takes precedence):
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/security_service?sslmode=disable

# ---- Redis ----
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ---- JWT ----
# IMPORTANT: Change this to a strong random secret in production.
JWT_SECRET=change-me-in-production
